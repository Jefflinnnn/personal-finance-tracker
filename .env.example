# Database
DATABASE_URL=postgresql://finance:finance_local@localhost:5432/finance_tracker

# Teller (https://teller.io/docs)
NEXT_PUBLIC_TELLER_APP_ID=
NEXT_PUBLIC_TELLER_ENV=sandbox
TELLER_CERT_PATH=./teller/certificate.pem
TELLER_KEY_PATH=./teller/private_key.pem

# AWS (for Claude via Bedrock)
AWS_REGION=us-west-2
# Credentials loaded from ~/.aws/credentials by default

# Discord Webhook
DISCORD_WEBHOOK_URL=

# API Auth (generate with: openssl rand -hex 32)
FINANCE_API_KEY=
